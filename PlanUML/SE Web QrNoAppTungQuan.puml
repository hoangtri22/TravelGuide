@startuml
title SE Web QrNoAppTungQuan
actor "Admin / nhân viên" as A
participant "TravelGuide.AdminWeb/WEB/qr-noapp.html async function loadPois()" as FE
participant "TravelGuide.AdminWeb/WEB/qr-noapp.html function renderPois(pois, baseUrl)" as RENDER
participant "TravelGuide.AdminWeb/WEB/qr-noapp.html function buildScanUrl(baseUrl, poiId)" as SCAN
participant "TravelGuide.AdminWeb/WEB/qr-noapp.html function buildQrImageUrl(targetUrl)" as QRURL
participant "TravelGuide.AdminWeb/Program.cs MapGet(\"/api/public/pois\")" as API
A -> FE : Mở qr-noapp.html (auto loadPois on load)
FE -> API : fetch(\"/api/public/pois\")
API --> FE : JSON
FE -> RENDER : renderPois(data, baseUrl)
RENDER -> SCAN : buildScanUrl(baseUrl, id) -> .../scan-poi.html?id=
RENDER -> QRURL : buildQrImageUrl(targetUrl) -> https://api.qrserver.com/v1/create-qr-code/?...
RENDER --> A : thẻ <img> + link mở scan-poi
@enduml
