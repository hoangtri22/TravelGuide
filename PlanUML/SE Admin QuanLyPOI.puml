@startuml
title SE Admin QuanLyPOI
skinparam shadowing false
skinparam monochrome true
actor Admin as A
participant "WEB/app.js\nloadPois + UI handlers" as FE
participant "app.js\napi(url, options)" as APIJS
participant "Program.cs\nGET /api/pois" as GET
participant "Program.cs\nPOST /api/pois" as POST
participant "Program.cs\nPUT /api/pois/{id}" as PUT
participant "Program.cs\nDELETE /api/pois/{id}" as DEL
participant "Program.cs\nPUT /api/pois/{id}/approve" as APP
participant "Program.cs\nPUT /api/pois/{id}/reject" as REJ
A -> FE : Tab POI / refresh
FE -> APIJS : await api(/api/pois)
APIJS -> GET : GET /api/pois
alt tạo POI
  A -[hidden]-> FE
  APIJS -[hidden]-> REJ
  FE -> APIJS : await api(/api/pois, { method: POST, ... })
  APIJS -> POST : tạo POI mới
else sửa POI
  A -[hidden]-> FE
  APIJS -[hidden]-> REJ
  FE -> APIJS : await api(`/api/pois/${id}`, { method: PUT, ... })
  APIJS -> PUT : cập nhật POI
else xóa POI
  A -[hidden]-> FE
  APIJS -[hidden]-> REJ
  FE -> APIJS : await api(`/api/pois/${id}`, { method: DELETE })
  APIJS -> DEL : xóa POI
else duyệt / từ chối
  A -[hidden]-> FE
  APIJS -[hidden]-> REJ
  FE -> APIJS : await api(`/api/pois/${id}/approve`, { method: PUT })
  APIJS -> APP : publish POI
  FE -> APIJS : await api(`/api/pois/${id}/reject`, { method: PUT, body: ... })
  APIJS -> REJ : reject POI
end
@enduml
