@startuml
title SE Admin Heatmap 
skinparam shadowing false
skinparam monochrome true
hide footbox

actor Admin as A
participant "app.js\nrefreshHeatmapTab()" as FE
participant "app.js\nensureLeafletHeatLibs()" as CDN
participant "app.js\napi(url, options)" as APIJS
participant "Program.cs\nGET /api/pois" as POIS
participant "Program.cs\nGET /api/tourists/poi-scan-dashboard" as DASH
database "TravelGuideDb\nGetTouristPoiScanDashboardAsync()" as DB

A -> FE : Chọn tab Heatmap / nút Làm mới bản đồ
FE -> FE : if (!pois?.length) await loadPois()
FE -> CDN : tải CSS/JS Leaflet + heat plugin (lần đầu)
FE -> APIJS : await api(/api/tourists/poi-scan-dashboard)
APIJS -> DASH : GET (Bearer admin)
DASH -> DB : dashboard heatmap theo POI (windowMinutes, recentGpsHits, tổng lượt truy cập, …)
DB --> DASH
DASH --> FE : JSON
FE -> FE : Ghép log ↔ POI quản trị (id hoặc tên VI)\nheatLayer + circleMarker popup
FE --> A : Bản đồ + bảng chỉ số truy cập theo POI


@enduml
