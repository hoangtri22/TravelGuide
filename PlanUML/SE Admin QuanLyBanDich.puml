@startuml
title SE Admin QuanLyBanDich
actor Admin as A
participant "TravelGuide.AdminWeb/WEB/app.js async function loadTranslation(id)" as FE
participant "TravelGuide.AdminWeb/WEB/app.js byId(\"translationForm\").addEventListener(\"submit\", ...)" as SUB
participant "TravelGuide.AdminWeb/WEB/app.js const api = async (url, options)" as APIJS
participant "TravelGuide.AdminWeb/Program.cs MapGet(\"/api/translations/{id}\")" as GET
participant "TravelGuide.AdminWeb/Program.cs MapPut(\"/api/translations/{id}\")" as PUT
participant "TravelGuide.AdminWeb/Program.cs MapPost(\"/api/translations/{id}/regenerate\")" as REG
database "TravelGuideDb.EnsureAutoTranslationsAsync()" as AUTO
database "TravelGuideDb.UpdateTranslationsAsync()" as DB
database "TravelGuideDb.ClearTranslationsAsync()" as CLR
A -> FE : Chọn POI / await loadTranslation(id)
FE -> APIJS : await api(`/api/translations/${id}?lang=...`)
APIJS -> GET : GET handler
GET -> AUTO : await EnsureAutoTranslationsAsync(httpClient, id, lang)
GET -> GET : await GetPoiAsync(id)
GET --> FE : PoiDto JSON
A -> SUB : submit translationForm
SUB -> APIJS : await api(`/api/translations/${id}`, { method: \"PUT\", body: ... })
APIJS -> PUT : MapPut handler
PUT -> DB : await UpdateTranslationsAsync(id, request)
PUT --> FE : 200/404
alt nút Tạo lại / regenerate (app.js)
  A -> FE : bấm Tạo lại (ngôn ngữ đang chọn)
  FE -> APIJS : await api(`/api/translations/${id}/regenerate?lang=...`, { method: \"POST\" })
  APIJS -> REG : MapPost handler
  REG -> CLR : ClearTranslationsAsync(id, lang)
  REG -> AUTO : EnsureAutoTranslationsAsync rồi GetPoiAsync
  REG --> FE : PoiDto JSON mới
end
@enduml
