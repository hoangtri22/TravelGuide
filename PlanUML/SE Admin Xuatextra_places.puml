@startuml
title SE Admin Xuatextra_places
actor Admin as A
participant "TravelGuide.AdminWeb/WEB/app.js byId(\"exportBtn\").addEventListener(\"click\", ...)" as FE
participant "TravelGuide.AdminWeb/WEB/app.js const api = async (url, options)" as APIJS
participant "TravelGuide.AdminWeb/Program.cs MapGet(\"/api/export/extra_places.json\")" as API
database "TravelGuideDb.GetExportPlacesAsync()" as DB
A -> FE : Click Export
FE -> APIJS : await api(\"/api/export/extra_places.json\")
APIJS -> API : GET (Bearer admin)
API -> DB : await GetExportPlacesAsync()
DB --> API : List<ExportPoi>
API --> FE : JSON
FE -> FE : Blob + a.download = extra_places.json
@enduml
