@startuml
title SE Admin QuanLyTaiKhoan
actor Admin as A
participant "TravelGuide.AdminWeb/WEB/app.js async function loadAccounts()" as FE
participant "TravelGuide.AdminWeb/WEB/app.js const api = async (url, options)" as APIJS
participant "TravelGuide.AdminWeb/Program.cs MapGet(\"/api/accounts\")" as GET
participant "TravelGuide.AdminWeb/Program.cs MapPost(\"/api/accounts\")" as POST
participant "TravelGuide.AdminWeb/Program.cs MapPut(\"/api/accounts/{id}/lock\")" as LOCK
participant "TravelGuide.AdminWeb/Program.cs MapPut(\"/api/accounts/{id}/approve-registration\")" as APPROVE
participant "TravelGuide.AdminWeb/Program.cs MapPut(\"/api/accounts/{id}/reject-registration\")" as REJECT
participant "TravelGuide.AdminWeb/Program.cs MapDelete(\"/api/accounts/{id}\")" as DELETE
database "TravelGuideDb.GetUsersAsync()" as DB
A -> FE : Tab account
FE -> APIJS : await api(\"/api/accounts\")
APIJS -> GET : GET /api/accounts
GET -> DB : await GetUsersAsync()
GET --> FE : JSON users
alt tạo account
  FE -> APIJS : await api(\"/api/accounts\", { method: \"POST\", ... })
  APIJS -> POST : MapPost
else khóa / mở khóa
  FE -> APIJS : await api(`/api/accounts/${id}/lock`, { method: \"PUT\", ... })
  APIJS -> LOCK : MapPut lock
else duyệt / từ chối đăng ký owner
  FE -> APIJS : await api(`/api/accounts/${id}/approve-registration`, { method: \"PUT\" })
  APIJS -> APPROVE : MapPut
  FE -> APIJS : await api(`/api/accounts/${id}/reject-registration`, { method: \"PUT\" })
  APIJS -> REJECT : MapPut
else xóa account
  FE -> APIJS : await api(`/api/accounts/${id}`, { method: \"DELETE\" })
  APIJS -> DELETE : MapDelete
end
@enduml
