@startuml
title SE Admin UploadAudio
actor "Admin hoặc chủ quán" as U
participant "TravelGuide.AdminWeb/WEB/poi-create.js byId(\"poiForm\")?.addEventListener(\"submit\", ...)" as POIFORM
participant "TravelGuide.AdminWeb/WEB/poi-create.js const apiMultipart = async (url, formData)" as POIMULTI
participant "TravelGuide.AdminWeb/WEB/app.js byId(\"audioTableWrap\")?.addEventListener(\"click\", ...)" as AUDIOWRAP
participant "TravelGuide.AdminWeb/WEB/app.js const apiMultipart = async (url, formData)" as APPMULTI
participant "TravelGuide.AdminWeb/Program.cs MapPost(\"/api/upload/audio\")" as API
participant "TravelGuide.AdminWeb.Auth.AuthHelper.Authenticate()" as AUTH
participant "TravelGuide.AdminWeb/Program.cs SaveUploadedAudioAsync()" as SAVE
alt upload khi submit poi-create (có audioFile)
  U -> POIFORM : submit (đoạn await apiMultipart trong handler)
  POIFORM -> POIMULTI : await apiMultipart(\"/api/upload/audio\", fd)
  POIMULTI -> API : POST multipart field \"file\"
  API -> AUTH : AuthHelper.Authenticate(context, authStore)
  API -> SAVE : await SaveUploadedAudioAsync(file, env, context.RequestAborted)
  SAVE --> API : relativePath
  API --> POIMULTI : { audioUrl }
else upload từ tab Audio (click .audio-upload-btn)
  U -> AUDIOWRAP : handler upload branch
  AUDIOWRAP -> APPMULTI : await apiMultipart(\"/api/upload/audio\", fd)
  APPMULTI -> API : POST multipart field \"file\"
  API -> AUTH : AuthHelper.Authenticate(context, authStore)
  API -> SAVE : await SaveUploadedAudioAsync(file, env, context.RequestAborted)
  SAVE --> API : relativePath
  API --> APPMULTI : { audioUrl }
end
@enduml
