@startuml
left to right direction
skinparam shadowing false
skinparam monochrome true
actor "Chủ quán" as O
rectangle "Owner Web (cùng TravelGuide.AdminWeb/WEB/index.html)" {
  usecase "Đăng ký chủ quán chờ duyệt\nPOST /api/auth/register" as O0
  usecase "Đăng nhập JWT sessionStorage\nPOST /api/auth/login" as O1
  usecase "Quản lý POI quán (scope owner)\nGET /api/pois" as O2
  usecase "Form tạo/sửa POI\nTravelGuide.AdminWeb/WEB/poi-create.html\nPOST /api/upload/poi-image\nPOST /api/upload/audio\nPOST|PUT /api/pois" as O3
  usecase "Bản dịch POI\n/api/translations/{id}" as O4
  usecase "Audio + map link tab\nPOST /api/upload/audio\nPUT /api/pois/{id}" as O5
}

O0 -[hidden]down- O1
O1 -[hidden]down- O2
O2 -[hidden]down- O4
O4 -[hidden]down- O5
O2 -[hidden]right- O3

O --> O0
O --> O1
O --> O2
O --> O4
O --> O5
O2 .> O3 : <<include>>
@enduml
