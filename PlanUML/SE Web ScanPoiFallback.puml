@startuml
title SE Web ScanPoiFallback
actor "Người dùng (trình duyệt)" as U
participant "TravelGuide.AdminWeb/WEB/scan-poi.html function loadData()" as FE
participant "TravelGuide.AdminWeb/WEB/scan-poi.html function getPoiIdFromQuery()" as QID
participant "TravelGuide.AdminWeb/Program.cs MapGet(\"/api/public/pois\")" as API
database "TravelGuide.AdminWeb.Data.TravelGuideDb" as DB
U -> FE : GET /scan-poi.html?id=<poiId>
FE -> QID : getPoiIdFromQuery()
FE -> API : fetch(\"/api/public/pois\", { headers: { Accept: \"application/json\" } })
API -> DB : await EnsureAutoTranslationsAsync(httpClientFactory.CreateClient(), targetLang: lang)
API -> DB : await GetPoisAsync(includeUnpublished: false)
API --> FE : JSON array
FE -> FE : Array.find(id) trong script inline
@enduml
