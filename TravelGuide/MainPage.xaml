<?xml version="1.0" encoding="utf-8" ?>
<!-- MainPage: chọn ngôn ngữ / tiền tệ, vào Home -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             x:Class="TravelGuide.MainPage"
             BackgroundColor="#F3F6FB"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <Grid HeightRequest="220">
                    <Image Source="travel.jpg" Aspect="AspectFill"/>
                    <BoxView VerticalOptions="End" HeightRequest="80">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="White" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                </Grid>

                <VerticalStackLayout Padding="20" Spacing="16" Margin="0,-28,0,0">

                    <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="16">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{loc:Translate WelcomeText}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0F172A, Dark=#F8FAFC}"/>
                            <Label Text="{loc:Translate SetupJourney}" FontSize="13" TextColor="{AppThemeBinding Light=#64748B, Dark=#CBD5E1}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{loc:Translate LanguageLabel}"
                               FontAttributes="Bold" TextColor="{AppThemeBinding Light=#555555, Dark=#E5E7EB}" FontSize="14"/>

                        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8">

                            <Border x:Name="BtnLang_vi" Grid.Column="0"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#1E88E5" StrokeThickness="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLanguageTapped" CommandParameter="vi"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Padding="4,10" Spacing="3" HorizontalOptions="Center">
                                    <Label Text="🇻🇳" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="VI" FontSize="11" FontAttributes="Bold"
                                           TextColor="White" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border x:Name="BtnLang_en" Grid.Column="1"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#F1F5F9" StrokeThickness="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLanguageTapped" CommandParameter="en"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Padding="4,10" Spacing="3" HorizontalOptions="Center">
                                    <Label Text="🇬🇧" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="EN" FontSize="11" FontAttributes="Bold"
                                           TextColor="#555555" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border x:Name="BtnLang_ja" Grid.Column="2"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#F1F5F9" StrokeThickness="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLanguageTapped" CommandParameter="ja"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Padding="4,10" Spacing="3" HorizontalOptions="Center">
                                    <Label Text="🇯🇵" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="JA" FontSize="11" FontAttributes="Bold"
                                           TextColor="#555555" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border x:Name="BtnLang_ko" Grid.Column="3"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#F1F5F9" StrokeThickness="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLanguageTapped" CommandParameter="ko"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Padding="4,10" Spacing="3" HorizontalOptions="Center">
                                    <Label Text="🇰🇷" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="KO" FontSize="11" FontAttributes="Bold"
                                           TextColor="#555555" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border x:Name="BtnLang_zh" Grid.Column="4"
                                    StrokeShape="RoundRectangle 12"
                                    BackgroundColor="#F1F5F9" StrokeThickness="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLanguageTapped" CommandParameter="zh"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Padding="4,10" Spacing="3" HorizontalOptions="Center">
                                    <Label Text="🇨🇳" FontSize="22" HorizontalOptions="Center"/>
                                    <Label Text="ZH" FontSize="11" FontAttributes="Bold"
                                           TextColor="#555555" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                        </Grid>

                        <!-- Tên ngôn ngữ đang chọn -->
                        <Label x:Name="LblSelectedLang"
                               Text="🇻🇳 Tiếng Việt"
                               FontSize="13" TextColor="#1E88E5"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout></Border>

                    <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{loc:Translate CurrencyLabel}"
                               FontAttributes="Bold" TextColor="{AppThemeBinding Light=#555555, Dark=#E5E7EB}" FontSize="14"/>
                        <Border StrokeShape="RoundRectangle 12" Padding="10,0"
                                Stroke="#E0E0E0" HeightRequest="45">
                            <Entry x:Name="CurrencyEntry"
                                   Placeholder="{loc:Translate CurrencyPlaceholder}"
                                   TextChanged="OnCurrencySearch"
                                   VerticalOptions="Center"/>
                        </Border>

                        <Border x:Name="CurrencyListFrame" IsVisible="False"
                                StrokeShape="RoundRectangle 10" BackgroundColor="White"
                                Stroke="#D1D1D1" HeightRequest="150">
                            <CollectionView x:Name="CurrencyCollection"
                                            SelectionMode="Single"
                                            SelectionChanged="OnCurrencySelected">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Label Text="{Binding .}" Padding="15,10"
                                               FontSize="14" TextColor="{AppThemeBinding Light=#333333, Dark=#F1F5F9}"/>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                    </VerticalStackLayout></Border>

                    <Button x:Name="ContinueBtn"
                            Text="{loc:Translate BtnContinue}"
                            Clicked="GoHome"
                            BackgroundColor="#1E88E5"
                            TextColor="White"
                            CornerRadius="25"
                            HeightRequest="50"
                            FontAttributes="Bold"
                            Margin="0,5,0,20"/>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>