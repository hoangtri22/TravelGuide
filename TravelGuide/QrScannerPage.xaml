<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TravelGuide"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             xmlns:loc="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             x:Class="TravelGuide.QrScannerPage"
             Title="Quét QR">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Padding="16" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Label Grid.Column="0"
                   Text="Đưa mã QR vào khung để mở địa điểm"
                   FontAttributes="Bold"
                   TextColor="#0B1E34"
                   VerticalOptions="Center"/>
            <Button Grid.Column="1"
                    Text="{loc:Translate NavTabScanHistory}"
                    FontSize="12"
                    Padding="12,8"
                    BackgroundColor="#E8F4FC"
                    TextColor="#0B74B2"
                    Clicked="OnOpenScanHistoryClicked"/>
        </Grid>

        <Border Grid.Row="1" Stroke="#0B74B2" StrokeThickness="2" StrokeShape="RoundRectangle 16">
            <zxing:CameraBarcodeReaderView x:Name="CameraView"
                                           BarcodesDetected="OnBarcodesDetected"
                                           IsDetecting="True" />
        </Border>

        <Label Grid.Row="2" x:Name="StatusLabel"
               Text="Sẵn sàng quét"
               HorizontalTextAlignment="Center"
               TextColor="#64748B" />

        <local:BottomNavBarView Grid.Row="3"/>
    </Grid>
</ContentPage>
