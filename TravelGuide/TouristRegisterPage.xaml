<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelGuide.TouristRegisterPage"
             Title="Sign Up"
             BackgroundColor="#F3F6FB">
    <ScrollView>
        <VerticalStackLayout Padding="22,24,22,28" Spacing="16">
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Border StrokeThickness="0" BackgroundColor="#0E91D8" StrokeShape="RoundRectangle 24" Padding="16">
                    <Label Text="✈" FontSize="42" HorizontalOptions="Center" TextColor="#EAF6FF" FontAttributes="Bold"/>
                </Border>
                <Label Text="TravelGo" FontSize="36" FontAttributes="Bold" TextColor="#0077BE" HorizontalTextAlignment="Center" HorizontalOptions="Center"/>
                <Label Text="Create your account and start exploring" FontSize="13" TextColor="#75839A" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4" Margin="0,8,0,0" HorizontalOptions="Center">
                <Label Text="Create account ✨" FontSize="24" FontAttributes="Bold" TextColor="#1E293B" HorizontalTextAlignment="Center"/>
                <Label Text="Sign up as a tourist in seconds" FontSize="13" TextColor="#6B7A90" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <Border StrokeThickness="0" BackgroundColor="#EEF4FB" StrokeShape="RoundRectangle 20" Padding="16" Margin="0,4,0,0">
                <VerticalStackLayout Spacing="12">
                    <VerticalStackLayout Spacing="8">
                <Label Text="Username" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                <Border Stroke="#CBD5E1" StrokeThickness="2" StrokeShape="RoundRectangle 14" BackgroundColor="White" Padding="14,10">
                    <Entry x:Name="UsernameEntry" Placeholder="Choose a username" FontSize="16"/>
                </Border>
            </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                <Label Text="Display name" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                <Border Stroke="#CBD5E1" StrokeThickness="2" StrokeShape="RoundRectangle 14" BackgroundColor="White" Padding="14,10">
                    <Entry x:Name="DisplayNameEntry" Placeholder="How others will see you" FontSize="16"/>
                </Border>
            </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                <Label Text="Password" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                <Border Stroke="#CBD5E1" StrokeThickness="2" StrokeShape="RoundRectangle 14" BackgroundColor="White" Padding="14,10">
                    <Entry x:Name="PasswordEntry" Placeholder="Enter a secure password" IsPassword="True" FontSize="16"/>
                </Border>
            </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                <Label Text="Gói tài khoản" FontSize="16" FontAttributes="Bold" TextColor="#374151"/>
                <Label Text="Free: 1.000đ mỗi lần mở quán qua quét QR. Premium: 60.000đ khi quét mã kích hoạt (mục Quét QR). Chủ quán đăng POI: 100.000đ/tháng mỗi địa điểm (Admin)." FontSize="12" TextColor="#64748B"/>
            </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="🚀  Sign Up"
                    Clicked="OnRegisterClicked"
                    HeightRequest="56"
                    CornerRadius="16"
                    FontAttributes="Bold"
                    FontSize="17"
                    TextColor="White">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#12A4E6" Offset="0"/>
                        <GradientStop Color="#0B74B2" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Already have an account?" FontSize="14" TextColor="#64748B"/>
                <Label Text="Sign in" FontSize="14" FontAttributes="Bold" TextColor="#0EA5E9">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackToLoginTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
