<?xml version="1.0" encoding="utf-8" ?>
<!-- HomePage: danh sách địa điểm, tìm kiếm, lối tới Map / Audio -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TravelGuide"
             xmlns:loc="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             x:Class="TravelGuide.HomePage"
             BackgroundColor="#EEF2F6"
             Title="{loc:Translate AppTitle}">

    <ContentPage.Resources>
        <Style x:Key="CategoryBtnStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="TextColor" Value="#2563EB"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="46"/>
            <Setter Property="BorderColor" Value="#E2E8F0"/>
            <Setter Property="BorderWidth" Value="1"/>
            <Setter Property="Shadow">
                <Shadow Brush="#0F172A" Offset="0,2" Radius="6" Opacity="0.05"/>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="16">

                <Border StrokeThickness="0" StrokeShape="RoundRectangle 22" Padding="20,18">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#F4F7FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#0F172A" Offset="0,8" Radius="20" Opacity="0.06"/>
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="10" ColumnSpacing="12">
                        <Label Grid.Row="0" Grid.ColumnSpan="2"
                               Text="{loc:Translate HomeHeroTitle}"
                               FontSize="22" FontAttributes="Bold" TextColor="#0B1220"/>
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="{loc:Translate AppTagline}"
                               FontSize="14" TextColor="#64748B" LineBreakMode="WordWrap"
                               VerticalOptions="Center"/>
                        <Border Grid.Row="1" Grid.Column="1"
                                BackgroundColor="#EEF2FF" Padding="14,10"
                                StrokeThickness="0" StrokeShape="RoundRectangle 18"
                                VerticalOptions="Center">
                            <Label x:Name="LblTotalPoi"
                                   FontSize="12" FontAttributes="Bold" TextColor="#4338CA"
                                   HorizontalTextAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border StrokeShape="RoundRectangle 16"
                        Padding="4" BackgroundColor="White"
                        Stroke="#E2E8F0" StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="#0F172A" Offset="0,2" Radius="8" Opacity="0.04"/>
                    </Border.Shadow>
                    <SearchBar Placeholder="{loc:Translate SearchPlaceholder}"
                               TextChanged="OnSearchBarTextChanged"/>
                </Border>

                <!-- FIX: Grid 3 cột đều nhau thay FlexLayout — tránh bị cắt chữ khi đổi ngôn ngữ -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="{loc:Translate BtnMap}"
                            Style="{StaticResource CategoryBtnStyle}"
                            Clicked="OpenMap"/>
                    <Button Grid.Column="1"
                            Text="{loc:Translate BtnAudio}"
                            Style="{StaticResource CategoryBtnStyle}"
                            Clicked="OpenAudio"/>
                    <Button Grid.Column="2"
                            Text="{loc:Translate BtnNearby}"
                            Style="{StaticResource CategoryBtnStyle}"
                            Clicked="OpenNearby"/>
                </Grid>

                <Label Text="{loc:Translate PopularPlaces}"
                       FontSize="20" FontAttributes="Bold"
                       Margin="2,6,0,0" TextColor="#0F172A"/>

                <CollectionView x:Name="PlacesCollection"
                                SelectionMode="Single"
                                SelectionChanged="OnPlaceSelected">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 15"
                                    StrokeThickness="0"
                                    BackgroundColor="White"
                                    Margin="0,5">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,5"
                                            Radius="10" Opacity="0.1"/>
                                </Border.Shadow>
                                <Grid RowDefinitions="180, Auto">
                                    <Image Source="{Binding ImageSource}"
                                           Aspect="AspectFill" Grid.Row="0"/>
                                    <VerticalStackLayout Grid.Row="1"
                                                         Padding="15" Spacing="5">
                                        <Label Text="{Binding Name}"
                                               FontSize="18" FontAttributes="Bold"
                                               TextColor="#0F172A"/>
                                        <Label Text="{Binding Summary}"
                                               FontSize="13" TextColor="Gray"
                                               MaxLines="2"/>
                                        <Label Text="{loc:Translate ViewDetail}"
                                               FontSize="12" TextColor="#2E86DE"
                                               Margin="0,5,0,0"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <local:MiniPlayerView x:Name="MiniPlayer" Grid.Row="1"/>

    </Grid>
</ContentPage>
