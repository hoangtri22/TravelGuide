<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TravelGuide"
             xmlns:loc="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             x:Class="TravelGuide.HomePage"
             BackgroundColor="#F3F6FB"
             Title="{loc:Translate AppTitle}">

    <ContentPage.Resources>
        <Style x:Key="CategoryBtnStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="TextColor" Value="#2E86DE"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontAttributes" Value="Bold"/>
            <Setter Property="HeightRequest" Value="45"/>
            <Setter Property="BorderColor" Value="#E0E0E0"/>
            <Setter Property="BorderWidth" Value="1"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="16" Spacing="14">

                <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 18" Padding="16">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label x:Name="LblDashboardTitle" Grid.Row="0" Grid.Column="0" Text="Dashboard"
                               FontSize="28" FontAttributes="Bold" TextColor="#0F172A"/>
                        <Label Grid.Row="1" Grid.Column="0" Text="{loc:Translate AppTagline}"
                               FontSize="13" TextColor="#64748B"/>
                        <Border Grid.RowSpan="2" Grid.Column="1" BackgroundColor="#DBEAFE" Padding="10,6" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                            <Label x:Name="LblTotalPoi" Text="0 POI" FontAttributes="Bold" TextColor="#1D4ED8"/>
                        </Border>
                    </Grid>
                </Border>

                <Border StrokeShape="RoundRectangle 14"
                        Padding="5" BackgroundColor="White"
                        Stroke="#E2E8F0" StrokeThickness="1">
                    <SearchBar Placeholder="{loc:Translate SearchPlaceholder}"
                               TextChanged="OnSearchBarTextChanged"/>
                </Border>

                <!-- FIX: Grid 3 cột đều nhau thay FlexLayout — tránh bị cắt chữ khi đổi ngôn ngữ -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="{loc:Translate BtnMap}"
                            Style="{StaticResource CategoryBtnStyle}"
                            Clicked="OpenMap"/>
                    <Button Grid.Column="1"
                            Text="{loc:Translate BtnAudio}"
                            Style="{StaticResource CategoryBtnStyle}"
                            Clicked="OpenAudio"/>
                    <Button Grid.Column="2"
                            Text="{loc:Translate BtnNearby}"
                            Style="{StaticResource CategoryBtnStyle}"
                            Clicked="OpenNearby"/>
                </Grid>

                <Label Text="{loc:Translate PopularPlaces}"
                       FontSize="20" FontAttributes="Bold"
                       Margin="2,6,0,0" TextColor="#0F172A"/>

                <CollectionView x:Name="PlacesCollection"
                                SelectionMode="Single"
                                SelectionChanged="OnPlaceSelected">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 15"
                                    StrokeThickness="0"
                                    BackgroundColor="White"
                                    Margin="0,5">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,5"
                                            Radius="10" Opacity="0.1"/>
                                </Border.Shadow>
                                <Grid RowDefinitions="180, Auto">
                                    <Image Source="{Binding ImageSource}"
                                           Aspect="AspectFill" Grid.Row="0"/>
                                    <VerticalStackLayout Grid.Row="1"
                                                         Padding="15" Spacing="5">
                                        <Label Text="{Binding Name}"
                                               FontSize="18" FontAttributes="Bold"
                                               TextColor="#0F172A"/>
                                        <Label Text="{Binding Summary}"
                                               FontSize="13" TextColor="Gray"
                                               MaxLines="2"/>
                                        <Label Text="{loc:Translate ViewDetail}"
                                               FontSize="12" TextColor="#2E86DE"
                                               Margin="0,5,0,0"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <local:MiniPlayerView x:Name="MiniPlayer" Grid.Row="1"/>

    </Grid>
</ContentPage>
