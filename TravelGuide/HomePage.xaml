<?xml version="1.0" encoding="utf-8" ?>
<!-- HomePage: danh sách địa điểm, tìm kiếm, lối tới Map / Audio -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TravelGuide"
             xmlns:loc="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             x:Class="TravelGuide.HomePage"
             BackgroundColor="#F3F6FB"
             Title="{loc:Translate AppTitle}">

    <Grid RowDefinitions="*,Auto,Auto">
        <ScrollView x:Name="MainScroll" Grid.Row="0">
            <VerticalStackLayout Spacing="0">
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 0,0,30,30">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#12A4E6" Offset="0"/>
                            <GradientStop Color="#0B74B2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Padding="20,18,20,28" Spacing="14">
                        <Button x:Name="LanguageButton"
                                WidthRequest="140"
                                HeightRequest="38"
                                HorizontalOptions="End"
                                CornerRadius="16"
                                BackgroundColor="#1C85BE"
                                TextColor="White"
                                FontAttributes="Bold"
                                Clicked="OnLanguageButtonClicked"/>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="TravelGuide" FontSize="34" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="{loc:Translate AppTagline}" FontSize="13" TextColor="#DBEEFF"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{loc:Translate HomeGreeting}" FontSize="30" FontAttributes="Bold" TextColor="White"/>
                            <Label Text="{loc:Translate HomeGreetingSub}" FontSize="13" TextColor="#DBEEFF"/>
                        </VerticalStackLayout>
                        <Border x:Name="PremiumCard"
                                StrokeThickness="0"
                                BackgroundColor="#FFFFFF"
                                StrokeShape="RoundRectangle 14"
                                Padding="12,10"
                                IsVisible="False">
                            <VerticalStackLayout Spacing="0">
                                <Button x:Name="BtnUpgradePremiumHome"
                                        Text="Nâng cấp Premium"
                                        Clicked="OnUpgradePremiumClicked"
                                        BackgroundColor="#F59E0B"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        HeightRequest="38"
                                        CornerRadius="12"
                                        IsVisible="False"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border StrokeThickness="0" BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 16" Padding="8,2">
                            <SearchBar Placeholder="{loc:Translate SearchPlaceholder}" TextChanged="OnSearchBarTextChanged"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Padding="16,14,16,16" Spacing="14">
                    <ScrollView Orientation="Horizontal">
                        <HorizontalStackLayout x:Name="CategoryChips" Spacing="8">
                            <Button x:Name="ChipAll"
                                    Text="🔥 Nổi bật"
                                    Clicked="OnCategoryChipClicked"
                                    CommandParameter="all"
                                    BackgroundColor="#1A7FD4"
                                    TextColor="White"
                                    CornerRadius="18"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    Padding="14,6"/>
                            <Button x:Name="ChipFood"
                                    Text="🍜 Ẩm thực"
                                    Clicked="OnCategoryChipClicked"
                                    CommandParameter="quán ăn"
                                    BackgroundColor="White"
                                    TextColor="#445566"
                                    CornerRadius="18"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    Padding="14,6"/>
                            <Button x:Name="ChipDrink"
                                    Text="☕ Cà phê"
                                    Clicked="OnCategoryChipClicked"
                                    CommandParameter="quán nước"
                                    BackgroundColor="White"
                                    TextColor="#445566"
                                    CornerRadius="18"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    Padding="14,6"/>
                            <Button x:Name="ChipSight"
                                    Text="🏛️ Di tích"
                                    Clicked="OnCategoryChipClicked"
                                    CommandParameter="di tích lịch sử"
                                    BackgroundColor="White"
                                    TextColor="#445566"
                                    CornerRadius="18"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    Padding="14,6"/>
                            <Button x:Name="ChipOther"
                                    Text="📍 Khác"
                                    Clicked="OnCategoryChipClicked"
                                    CommandParameter="địa điểm du lịch"
                                    BackgroundColor="White"
                                    TextColor="#445566"
                                    CornerRadius="18"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    Padding="14,6"/>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{loc:Translate HomeFeaturedTitle}" FontSize="24" FontAttributes="Bold" TextColor="#0B1E34"/>
                        <Label Grid.Column="1" x:Name="LblTotalPoi" VerticalOptions="End" TextColor="#0B74B2" FontAttributes="Bold"/>
                    </Grid>

                    <CollectionView x:Name="PlacesCollection"
                                    HeightRequest="290"
                                    SelectionMode="Single"
                                    SelectionChanged="OnPlaceSelected">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border WidthRequest="220" StrokeThickness="0" BackgroundColor="White" StrokeShape="RoundRectangle 18">
                                    <Grid RowDefinitions="140,Auto">
                                        <Grid Grid.Row="0" BackgroundColor="#E8ECF0">
                                            <Image Source="{Binding ImageSource}" Aspect="AspectFill"/>
                                            <Border BackgroundColor="#E8391D" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="8,4" Margin="10,10,0,0" HorizontalOptions="Start" VerticalOptions="Start">
                                                <Label Text="{Binding HotLabel}" FontSize="11" FontAttributes="Bold" TextColor="White"/>
                                            </Border>
                                        </Grid>
                                        <VerticalStackLayout Grid.Row="1" Padding="12,10,12,14" Spacing="4">
                                            <Label Text="{Binding Name}" FontSize="20" FontAttributes="Bold" TextColor="#0B1E34" LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding Summary}" FontSize="12" TextColor="#64748B" MaxLines="2"/>
                                            <Label Text="{loc:Translate ViewDetail}" FontSize="12" TextColor="#0B74B2"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="LblNearbyTitle" Text="📍 Gần bạn" FontSize="21" FontAttributes="Bold" TextColor="#0B1E34"/>
                        <Label x:Name="LblNearbyViewAll" Grid.Column="1" Text="Xem tất cả" VerticalOptions="End" TextColor="#0B74B2" FontAttributes="Bold"/>
                    </Grid>

                    <CollectionView x:Name="NearbyCollection"
                                    SelectionMode="Single"
                                    SelectionChanged="OnPlaceSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="0" BackgroundColor="White" StrokeShape="RoundRectangle 14" Padding="12" Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="64,*,Auto" ColumnSpacing="12">
                                        <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="#E8F4FF" StrokeShape="RoundRectangle 10">
                                            <Label Text="📍" HorizontalOptions="Center" VerticalOptions="Center" FontSize="26"/>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="#1A2A3A" LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding TagDisplay}" FontSize="12" TextColor="#7C8A9A"/>
                                            <Label Text="{Binding Summary}" FontSize="11" TextColor="#8A97A6" LineBreakMode="TailTruncation" MaxLines="1"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#9AA8B5" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <local:MiniPlayerView x:Name="MiniPlayer" Grid.Row="1"/>

        <local:BottomNavBarView Grid.Row="2"/>
    </Grid>
</ContentPage>
