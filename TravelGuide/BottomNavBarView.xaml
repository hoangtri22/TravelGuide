<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
             x:Class="TravelGuide.BottomNavBarView">
    <Border StrokeThickness="0"
            BackgroundColor="White"
            StrokeShape="RoundRectangle 20,20,0,0">
        <Grid Padding="6,10,6,14"
              ColumnDefinitions="*,*,*,*,*"
              ColumnSpacing="0">
            <Grid Grid.Column="0">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="🏠" FontSize="20" HorizontalTextAlignment="Center"/>
                    <Label Text="{loc:Translate HomeHeroTitle}" FontSize="11" TextColor="#64748B" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped"/>
                </Grid.GestureRecognizers>
            </Grid>

            <Grid Grid.Column="1">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="🗺️" FontSize="20" HorizontalTextAlignment="Center"/>
                    <Label Text="{loc:Translate MapTitle}" FontSize="11" TextColor="#64748B" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMapTapped"/>
                </Grid.GestureRecognizers>
            </Grid>

            <Grid Grid.Column="2">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="🎙" FontSize="20" HorizontalTextAlignment="Center"/>
                    <Label Text="{loc:Translate NavTabAudio}" FontSize="11" TextColor="#64748B" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAudioTapped"/>
                </Grid.GestureRecognizers>
            </Grid>

            <Grid Grid.Column="3">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="📷" FontSize="20" HorizontalTextAlignment="Center"/>
                    <Label Text="Quét QR" FontSize="11" TextColor="#64748B" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnQrTapped"/>
                </Grid.GestureRecognizers>
            </Grid>

            <Grid Grid.Column="4">
                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="📋" FontSize="20" HorizontalTextAlignment="Center"/>
                    <Label Text="{loc:Translate NavTabScanHistory}" FontSize="11" TextColor="#64748B" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHistoryTapped"/>
                </Grid.GestureRecognizers>
            </Grid>
        </Grid>
    </Border>
</ContentView>
